@model ExpenseTracker.Models.Expense
@{
    ViewData["Title"] = "Add Expense";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="form-page">
    <div class="card form-card">
        <div class="card-header">
            <h3 class="card-title">New Expense Entry</h3>
        </div>

        <form asp-action="Create" method="post" class="expense-form">
            @Html.AntiForgeryToken()

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Date" class="form-label">Date <span class="required">*</span></label>
                    <input asp-for="Date" type="date" class="form-input" />
                    <span asp-validation-for="Date" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Category" class="form-label">Category <span class="required">*</span></label>
                    <select asp-for="Category" class="form-input form-select">
                        <option value="">-- Select Category --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <span asp-validation-for="Category" class="validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Description <span class="required">*</span></label>
                <input asp-for="Description" type="text" class="form-input" placeholder="e.g. Grocery shopping at Walmart" />
                <span asp-validation-for="Description" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Amount" class="form-label">Amount ($) <span class="required">*</span></label>
                <div class="input-prefix-wrapper">
                    <span class="input-prefix">$</span>
                    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-input input-with-prefix" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">Notes <span class="optional">(optional)</span></label>
                <textarea asp-for="Notes" class="form-input form-textarea" rows="3" placeholder="Any additional notes..."></textarea>
                <span asp-validation-for="Notes" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    Save Expense
                </button>
                <a asp-controller="Expense" asp-action="Index" class="btn btn-ghost btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>
