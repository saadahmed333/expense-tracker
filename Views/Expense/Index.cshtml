@model List<ExpenseTracker.Models.Expense>
@{
    ViewData["Title"] = "All Expenses";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<!-- Filter Bar -->
<div class="card filter-card">
    <form method="get" asp-action="Index" class="filter-form">
        <div class="filter-group">
            <label class="filter-label">Search</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-input" placeholder="Search description..." />
        </div>
        <div class="filter-group">
            <label class="filter-label">Category</label>
            <select name="category" class="form-input form-select">
                <option value="All">All Categories</option>
                @foreach (var cat in categories)
                {
                    if (ViewBag.SelectedCategory == cat)
                    {
                        <option value="@cat" selected>@cat</option>
                    }
                    else
                    {
                        <option value="@cat">@cat</option>
                    }
                }
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label">From Date</label>
            <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-input" />
        </div>
        <div class="filter-group">
            <label class="filter-label">To Date</label>
            <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-input" />
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Index" class="btn btn-ghost">Clear</a>
        </div>
    </form>
</div>

<!-- Table Card -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title">
            Expenses
            <span class="badge">@Model.Count records</span>
        </h3>
        <div class="card-header-right">
            <span class="total-label">Total: <strong>@("$" + ((decimal)(ViewBag.Total ?? 0m)).ToString("N2"))</strong></span>
            <a asp-controller="Expense" asp-action="Create" class="btn btn-primary btn-sm">+ Add New</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="1.5">
                <rect x="2" y="5" width="20" height="14" rx="2"/>
                <line x1="2" y1="10" x2="22" y2="10"/>
            </svg>
            <p>No expenses found.</p>
            <a asp-controller="Expense" asp-action="Create" class="btn btn-primary">Add Your First Expense</a>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Notes</th>
                        <th class="text-right">Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rowNum = 1; }
                    @foreach (var expense in Model)
                    {
                        <tr>
                            <td class="row-num">@rowNum++</td>
                            <td class="date-cell">@expense.Date.ToString("MMM dd, yyyy")</td>
                            <td class="desc-cell">@expense.Description</td>
                            <td>
                                <span class="badge-category cat-badge-@expense.Category.ToLower()">@expense.Category</span>
                            </td>
                            <td class="notes-cell">@(expense.Notes ?? "-")</td>
                            <td class="amount-cell text-right">$@expense.Amount.ToString("N2")</td>
                            <td class="actions-cell text-center">
                                <a asp-controller="Expense" asp-action="Edit" asp-route-id="@expense.Id" class="btn-icon btn-edit" title="Edit">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </a>
                                <form asp-controller="Expense" asp-action="Delete" asp-route-id="@expense.Id" method="post" class="inline-form" onsubmit="return confirmDelete()">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-icon btn-delete" title="Delete">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6"/>
                                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                            <path d="M10 11v6"/><path d="M14 11v6"/>
                                            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                                        </svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-footer-row">
                        <td colspan="5" class="text-right footer-total-label">Grand Total</td>
                        <td class="text-right footer-total">@("$" + ((decimal)(ViewBag.Total ?? 0m)).ToString("N2"))</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
