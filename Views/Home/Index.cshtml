@using ExpenseTracker.Models
@{
    ViewData["Title"] = "Dashboard";
    var categoryTotals = ViewBag.CategoryTotals as List<CategoryTotal> ?? new List<CategoryTotal>();
    var recentExpenses = ViewBag.RecentExpenses as List<Expense> ?? new();
    decimal totalAmount = ViewBag.TotalAmount != null ? (decimal)ViewBag.TotalAmount : 0m;
    decimal maxCatTotal = categoryTotals.Count > 0 ? categoryTotals[0].Total : 1m;
}

<!-- Summary Cards -->
<div class="cards-grid">
    <div class="card stat-card">
        <div class="stat-icon" style="background:#EFF6FF; color:#2563EB">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
        </div>
        <div class="stat-info">
            <p class="stat-label">Total Expenses</p>
            <h2 class="stat-value">@("$" + totalAmount.ToString("N2"))</h2>
            <p class="stat-sub">All time</p>
        </div>
    </div>

    <div class="card stat-card">
        <div class="stat-icon" style="background:#F0FDF4; color:#10B981">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
        </div>
        <div class="stat-info">
            <p class="stat-label">This Month</p>
            <h2 class="stat-value">@("$" + ((decimal)(ViewBag.MonthTotal ?? 0m)).ToString("N2"))</h2>
            <p class="stat-sub">@DateTime.Today.ToString("MMMM yyyy")</p>
        </div>
    </div>

    <div class="card stat-card">
        <div class="stat-icon" style="background:#FEF9C3; color:#D97706">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
        </div>
        <div class="stat-info">
            <p class="stat-label">Top Category</p>
            <h2 class="stat-value">@ViewBag.TopCategory</h2>
            <p class="stat-sub">Highest spending</p>
        </div>
    </div>

    <div class="card stat-card">
        <div class="stat-icon" style="background:#F5F3FF; color:#7C3AED">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div class="stat-info">
            <p class="stat-label">Transactions</p>
            <h2 class="stat-value">@ViewBag.TransactionCount</h2>
            <p class="stat-sub">Total records</p>
        </div>
    </div>
</div>

<!-- Charts + Recent -->
<div class="dashboard-grid">
    <!-- Category Breakdown -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Spending by Category</h3>
            <a asp-controller="Expense" asp-action="Index" class="card-link">View all</a>
        </div>
        <div class="chart-bars">
            @if (!categoryTotals.Any())
            {
                <p class="empty-msg">No expenses yet.</p>
            }
            @foreach (var cat in categoryTotals)
            {
                decimal pct = totalAmount > 0 ? (cat.Total / totalAmount * 100) : 0;
                decimal barWidth = maxCatTotal > 0 ? (cat.Total / maxCatTotal * 100) : 0;
                string catStr = cat.Category;
                <div class="bar-row">
                    <div class="bar-label">
                        <span class="cat-dot cat-@catStr.ToLower()"></span>
                        <span>@catStr</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill cat-bar-@catStr.ToLower()" style="width: @barWidth.ToString("F0")%"></div>
                    </div>
                    <div class="bar-amount">
                        <span>$@cat.Total.ToString("N2")</span>
                        <span class="bar-pct">@pct.ToString("F0")%</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Recent Expenses -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Recent Expenses</h3>
            <a asp-controller="Expense" asp-action="Index" class="card-link">View all</a>
        </div>
        @if (!recentExpenses.Any())
        {
            <p class="empty-msg">No expenses recorded yet.</p>
        }
        else
        {
            <div class="recent-list">
                @foreach (var exp in recentExpenses)
                {
                    <div class="recent-item">
                        <div class="recent-cat-icon cat-icon-@exp.Category.ToLower()">
                            @exp.Category[0]
                        </div>
                        <div class="recent-info">
                            <p class="recent-desc">@exp.Description</p>
                            <p class="recent-meta">@exp.Category &bull; @exp.Date.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="recent-amount">-$@exp.Amount.ToString("N2")</div>
                    </div>
                }
            </div>
        }
        <div class="card-footer">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-primary btn-sm">
                + Add New Expense
            </a>
        </div>
    </div>
</div>
