<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Expense Tracker</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                </div>
                <span class="logo-text">ExpenseTrack</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <p class="nav-label">Main Menu</p>
            <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                </svg>
                Dashboard
            </a>
            <a asp-controller="Expense" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Expense" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                    <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
                    <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
                All Expenses
            </a>
            <a asp-controller="Expense" asp-action="Create" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                Add Expense
            </a>

            <p class="nav-label" style="margin-top:1.5rem;">Categories</p>
            <a asp-controller="Expense" asp-action="Index" asp-route-category="Food" class="nav-link cat-link">
                <span class="cat-dot" style="background:#F59E0B"></span> Food
            </a>
            <a asp-controller="Expense" asp-action="Index" asp-route-category="Transport" class="nav-link cat-link">
                <span class="cat-dot" style="background:#3B82F6"></span> Transport
            </a>
            <a asp-controller="Expense" asp-action="Index" asp-route-category="Bills" class="nav-link cat-link">
                <span class="cat-dot" style="background:#EF4444"></span> Bills
            </a>
            <a asp-controller="Expense" asp-action="Index" asp-route-category="Entertainment" class="nav-link cat-link">
                <span class="cat-dot" style="background:#8B5CF6"></span> Entertainment
            </a>
            <a asp-controller="Expense" asp-action="Index" asp-route-category="Health" class="nav-link cat-link">
                <span class="cat-dot" style="background:#10B981"></span> Health
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Top Navbar -->
        <header class="topbar">
            <button class="menu-toggle" id="menuToggle" onclick="toggleSidebar()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-title">@ViewData["Title"]</div>
            <div class="topbar-right">
                <a asp-controller="Expense" asp-action="Create" class="btn-add-top">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add Expense
                </a>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    @TempData["Success"]
                    <button class="alert-close" onclick="this.parentElement.remove()">&#x2715;</button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
